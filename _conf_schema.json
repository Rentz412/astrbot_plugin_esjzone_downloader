{
  "download": {
    "description": "下载配置",
    "type": "object",
    "items": {
      "default_format": {
        "description": "默认导出格式",
        "type": "string",
        "options": ["epub", "txt"],
        "labels": ["EPUB", "TXT"],
        "default": "epub"
      },
      "concurrency": {
        "description": "章节下载并发数",
        "type": "int",
        "default": 5,
        "hint": "建议 1-10，过高可能触发站点限制。"
      },
      "enable_image_download": {
        "description": "生成 EPUB 时下载封面和正文插图",
        "type": "bool",
        "default": true
      },
      "allow_external_images": {
        "description": "允许下载外站图床图片",
        "type": "bool",
        "default": true,
        "hint": "ESJZone 的封面和插图经常托管在外部图床。开启后仅对图片下载放宽域名限制，页面和章节请求仍限制 ESJZone 域名。"
      },
      "request_timeout": {
        "description": "页面请求超时时间（秒）",
        "type": "int",
        "default": 15
      },
      "image_timeout": {
        "description": "图片请求超时时间（秒）",
        "type": "int",
        "default": 8
      },
      "max_retries": {
        "description": "章节/图片最大重试次数",
        "type": "int",
        "default": 3
      },
      "recent_chapter_count": {
        "description": "最近更新显示章节数",
        "type": "int",
        "default": 8
      },
      "user_agent": {
        "description": "请求 User-Agent",
        "type": "string",
        "default": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125 Safari/537.36"
      }
    }
  },
  "zip": {
    "description": "ZIP 打包配置",
    "type": "object",
    "items": {
      "password_mode": {
        "description": "压缩包密码模式",
        "type": "string",
        "options": ["book_id", "random", "fixed"],
        "labels": ["esj+书籍ID", "随机密码", "固定密码"],
        "default": "book_id"
      },
      "fixed_password": {
        "description": "固定压缩包密码",
        "type": "string",
        "default": "esjzone"
      },
      "random_password_length": {
        "description": "随机压缩包密码长度",
        "type": "int",
        "default": 8
      }
    }
  },
  "message": {
    "description": "消息输出配置",
    "type": "object",
    "items": {
      "private_verbose_status": {
        "description": "私聊使用详细回复",
        "type": "bool",
        "default": true
      },
      "group_mention_user": {
        "description": "群聊回复时 @ 发起用户",
        "type": "bool",
        "default": true
      },
      "group_verbose_status": {
        "description": "群聊使用详细回复（不推荐，可能刷屏）",
        "type": "bool",
        "default": false
      }
    }
  },
  "debug": {
    "description": "调试配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用 ESJZone 插件调试日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出 [esj.debug] 前缀日志，并按配置保存页面/诊断 JSON。"
      },
      "save_pages": {
        "description": "保存详情页和诊断 JSON",
        "type": "bool",
        "default": true
      },
      "save_auth_pages": {
        "description": "保存登录与个人资料页调试文件",
        "type": "bool",
        "default": true
      },
      "save_chapter_pages": {
        "description": "保存章节页 HTML",
        "type": "bool",
        "default": false,
        "hint": "章节很多时会产生大量文件，建议仅排查章节正文问题时开启。"
      }
    }
  },
  "dashboard": {
    "description": "Dashboard / WebUI 配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用 Dashboard / WebUI",
        "type": "bool",
        "default": false,
        "hint": "默认关闭以减少资源占用。开启后通过配置的 host:port 访问 WebUI；公网环境必须启用 Token 验证。"
      },
      "host": {
        "description": "WebUI 监听地址",
        "type": "string",
        "default": "127.0.0.1",
        "hint": "仅本机访问使用 127.0.0.1；需要局域网访问可设置为 0.0.0.0，并务必启用 Token。"
      },
      "port": {
        "description": "WebUI 访问端口",
        "type": "int",
        "default": 8989,
        "hint": "WebUI 必须通过带端口地址访问，例如 http://127.0.0.1:8989/。"
      },
      "public_base_url": {
        "description": "WebUI 对外访问基础地址",
        "type": "string",
        "default": "",
        "hint": "可选。反向代理或公网部署时填写，例如 https://example.com:8443；为空时按 host 和 port 生成访问提示。"
      },
      "auth_enabled": {
        "description": "启用 Dashboard Token 验证",
        "type": "bool",
        "default": true
      },
      "token": {
        "description": "Dashboard 访问 Token",
        "type": "string",
        "default": "",
        "hint": "为空时插件首次启动自动生成；公网环境请务必设置强 token。"
      }
    }
  },
  "proxy": {
    "description": "代理配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用 HTTP 代理",
        "type": "bool",
        "default": false
      },
      "url": {
        "description": "代理地址",
        "type": "string",
        "default": "",
        "hint": "例如 http://localhost:7899 或 socks5://127.0.0.1:7890"
      }
    }
  }
}
